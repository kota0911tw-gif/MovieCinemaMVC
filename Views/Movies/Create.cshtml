@model WebApplication1.Models.Movie

<h1>Create Movie</h1>

<form asp-action="Create" method="post">

    <div>
        <label>Title</label>
        <input asp-for="Title" />
    </div>

    <div>
        <label>Description</label>
        <input asp-for="Description" />
    </div>

    <div>
        <label>Price</label>
        <input asp-for="Price" />
    </div>

    <br />

    <button type="submit">
        Save
    </button>

</form>