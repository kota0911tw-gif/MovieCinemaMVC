@{
    ViewData["Title"] = "Home";
}

<div class="text-center">

    <h1 class="display-2 fw-bold">
        🎬 Movie Management System
    </h1>

    <p class="lead">
        Welcome to our online movie world.
    </p>

    <p>
        Browse movies, manage categories,
        and discover your favorite films.
    </p>

    <br />

    <a class="btn btn-primary btn-lg"
       href="/Movies">
        🎥 Browse Movies
    </a>

    <a class="btn btn-success btn-lg"
       href="/Categories">
        📂 Categories
    </a>

</div>

<hr />

<div class="row text-center">

    <div class="col-md-4">
        <h3>🔥 Popular Movies</h3>

        <img src="https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=600"
             class="img-fluid rounded" />

        <p>
            Explore trending movies and blockbuster hits.
        </p>
    </div>

    <div class="col-md-4">
        <h3>🍿 Cinema Experience</h3>

        <img src="https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c?w=600"
             class="img-fluid rounded" />

        <p>
            Enjoy the atmosphere of a modern cinema.
        </p>
    </div>

    <div class="col-md-4">
        <h3>⭐ Movie Collection</h3>

        <img src="https://images.unsplash.com/photo-1478720568477-152d9b164e26?w=600"
             class="img-fluid rounded" />

        <p>
            Organize and manage your favorite movies.
        </p>
    </div>

</div>

<hr />

<div class="text-center">

    <h2>About This Project</h2>

    <p>
        This project is developed using
        ASP.NET Core MVC and C#.
    </p>

    <p>
        Features include:
    </p>

    <ul class="list-group">
        <li class="list-group-item">Movie Management</li>
        <li class="list-group-item">Category Management</li>
        <li class="list-group-item">Create, Edit, Delete Operations</li>
        <li class="list-group-item">ASP.NET Core MVC Architecture</li>
    </ul>

</div>