@{
ViewData["Title"] = "Contact";
}

<div class="container mt-5">
    
<div class="text-center mb-5">

    <h1 class="display-2 fw-bold">
        📞 Contact Us
    </h1>

    <p class="lead text-muted">
        We'd love to hear from you
    </p>

</div>

<div class="row">

    <div class="col-md-6">

        <div class="card shadow-lg border-0">

            <div class="card-body p-4">

                <h3>📧 Send Message</h3>

                <hr />

                <form>

                    <div class="mb-3">

                        <label>Name</label>

                        <input type="text"
                               class="form-control" />

                    </div>

                    <div class="mb-3">

                        <label>Email</label>

                        <input type="email"
                               class="form-control" />

                    </div>

                    <div class="mb-3">

                        <label>Message</label>

                        <textarea class="form-control"
                                  rows="5"></textarea>

                    </div>

                    <button class="btn btn-primary btn-lg">

                        Send Message

                    </button>

                </form>

            </div>

        </div>

    </div>

    <div class="col-md-6">

        <div class="card shadow-lg border-0">

            <div class="card-body p-4">

                <h3>🎥 Movie Cinema</h3>

                <hr />

                <p>
                    📍 Taiwan
                </p>

                <p>
                    📧 moviecinema@example.com
                </p>

                <p>
                    📞 +886 123 456 789
                </p>

                <p>
                    🌐 ASP.NET Core MVC Final Project
                </p>

                <img src="https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c?w=1200"
                     class="img-fluid rounded mt-3" />

            </div>

        </div>

    </div>

</div>


</div>
