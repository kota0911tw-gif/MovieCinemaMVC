@{
    ViewData["Title"] = "About";
}

<div class="container mt-5">

    
    <div class="text-center mb-5">

        <h1 class="display-2 fw-bold">
            🎬 About Movie Cinema
        </h1>

        <p class="lead text-muted">
            ASP.NET Core MVC Movie Management System
        </p>

    </div>

    <div class="card shadow-lg border-0">

        <img src="https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=1200"
             class="card-img-top"
             style="height:350px; object-fit:cover;" />

        <div class="card-body p-5">

            <h2>📖 Project Overview</h2>

            <hr />

            <p class="lead">
                Movie Cinema is a modern movie management platform
                developed using ASP.NET Core MVC.
            </p>

            <p>
                This project demonstrates MVC architecture,
                CRUD operations, routing, controllers,
                models, views and responsive Bootstrap design.
            </p>

            <p>
                Users can browse movies, manage categories,
                place orders and access dashboard reports.
            </p>

        </div>

    </div>

    <div class="row mt-5">

        <div class="col-md-4">

            <div class="card shadow text-center">

                <div class="card-body">

                    <h1>🎬</h1>

                    <h3>Movies</h3>

                    <p>Manage movie information.</p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow text-center">

                <div class="card-body">

                    <h1>🛒</h1>

                    <h3>Shopping Cart</h3>

                    <p>Purchase your favorite movies.</p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow text-center">

                <div class="card-body">

                    <h1>📊</h1>

                    <h3>Dashboard</h3>

                    <p>Business analytics and reports.</p>

                </div>

            </div>

        </div>

    </div>
    

</div>