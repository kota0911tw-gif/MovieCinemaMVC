@model List<WebApplication1.Models.CartItem>

@{
ViewData["Title"] = "Shopping Cart";
}

<div class="container mt-5">
    
<div class="text-center mb-5">

    <h1 class="display-3 fw-bold">
        🛒 Shopping Cart
    </h1>

    <p class="lead text-muted">
        Review your selected movies before checkout.
    </p>

</div>

@if (!Model.Any())
{
    <div class="alert alert-warning text-center">

        <h3>Cart is Empty</h3>

        <p>
            Browse movies and add them to your cart.
        </p>

        <a href="/Movies"
           class="btn btn-primary btn-lg">
            🎬 Browse Movies
        </a>

    </div>
}
else
{
    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card shadow-lg h-100">

                    <img src="https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c?w=800"
                         class="card-img-top"
                         style="height:220px; object-fit:cover;" />

                    <div class="card-body">

                        <h3 class="card-title">
                            🎬 @item.MovieTitle
                        </h3>

                        <h4 class="text-success">
                            NT$ @item.Price
                        </h4>

                    </div>

                    <div class="card-footer text-center">

                        <a asp-action="Remove"
                           asp-route-movieId="@item.MovieId"
                           class="btn btn-danger">
                            🗑 Remove
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

    <div class="card shadow mt-4">

        <div class="card-body text-center">

            <h2>
                Total Price
            </h2>

            <h1 class="display-4 text-success">
                NT$ @Model.Sum(x => x.Price)
            </h1>

            <a href="/Checkout"
               class="btn btn-success btn-lg mt-3">
                💳 Proceed To Checkout
            </a>

        </div>

    </div>
}

</div>
